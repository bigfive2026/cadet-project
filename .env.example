# ArtBridge environment variables.
# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# Prisma / PostgreSQL (Neon, Supabase, or local)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=

# Mock auth (legacy): email of the seeded user to impersonate server-side.
# 사용하지 않음 — 아래 Auth.js 인증 사용. 예: creator@artbridge.demo
DEMO_USER_EMAIL=

# ── Auth.js v5 인증 ──
# AUTH_SECRET 생성: `openssl rand -hex 32`
AUTH_SECRET=
# 앱 기본 URL (OAuth callback). 예: http://localhost:3000
NEXT_PUBLIC_APP_URL=

# Google OAuth (선택) — Google Cloud Console에서 발급.
# 값이 없으면 Credentials(이메일/비밀번호) 로그인만 활성화된다.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Optional (uncomment when the feature is enabled) ──

# AI recommendation (OpenAI JSON schema). If empty, deterministic mock fallback is used.
OPENAI_API_KEY=

# Storage (Cloudinary / Supabase Storage) — only if image upload is enabled.
# CLOUDINARY_URL=
# SUPABASE_STORAGE_URL=
